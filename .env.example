# ============================================================
#  Madrasati ERP — environment variables
#  Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================

# --- Supabase (Project Settings → API) ---
# Public values — safe in the browser (protected by Row Level Security).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-publishable-key"

# Server-only — bypasses RLS. Used ONLY in server actions / route handlers
# for privileged admin operations (e.g. creating users, bulk import).
# Treat as a secret. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"

# --- AI features (optional; powers report-comment generation, at-risk
#     prediction summaries, NL search). Leave blank to disable AI features. ---
ANTHROPIC_API_KEY=""

# --- Communication providers (optional; Activities/Attendance notifications) ---
# WhatsApp Cloud API / Twilio / SMTP — wire in src/lib/notifications/*.
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
SMTP_URL=""
